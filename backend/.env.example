# ─── .env.example ─────────────────────────────────────────────────────────────
# انسخ هذا الملف إلى .env وعدّل القيم:
#   cp .env.example .env

# ── قاعدة البيانات (PostgreSQL) ───────────────────────────────────────────────
DATABASE_URL=postgresql://hepco:hepco_secret@localhost:5432/hepco_db

# ── الأمان ────────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-random-64-char-string-in-production

# ── Ollama (LLM) ───────────────────────────────────────────────────────────────
OLLAMA_BASE=http://localhost:11434
OLLAMA_MODEL=gemma3:4b

# ── نموذج التضمين (Embeddings) ────────────────────────────────────────────────
EMBED_BASE=http://localhost:11434
EMBED_MODEL=bge-m3

# ── Qdrant (Vector DB) ────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=hepco_kb
QDRANT_VECTOR_DIM=1024

# ── Logging ────────────────────────────────────────────────────────────────────
LOGS_DIR=logs
LOG_LEVEL=INFO
LOG_MAX_MB=20
LOG_BACKUPS=5
LOG_FORMAT=plain

# ── حماية تسجيل الدخول ────────────────────────────────────────────────────────
LOGIN_RATE_LIMIT=5
LOGIN_RATE_WINDOW=300
LOGIN_LOCKOUT_SEC=600

# ── Cache ──────────────────────────────────────────────────────────────────────
ANSWER_CACHE_MAX=512
ANSWER_CACHE_TTL=7200
ANSWER_CACHE_MIN_CONF=0.65

# ── CORS ───────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:5174
